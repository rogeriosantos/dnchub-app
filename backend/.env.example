# Application Settings
APP_NAME=FleetOptima
APP_ENV=development
DEBUG=true

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database Settings
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fleetoptima
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/fleetoptima

# JWT Settings
SECRET_KEY=your-super-secret-key-change-in-production-must-be-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=525600  # 365 days (1 year)
REFRESH_TOKEN_EXPIRE_DAYS=365       # 1 year

# CORS Settings
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Logging
LOG_LEVEL=INFO


  # Email (SMTP)
  SMTP_HOST=smtp.example.com
  SMTP_PORT=587
  SMTP_USER=your-email@example.com
  SMTP_PASSWORD=your-password
  SMTP_FROM_EMAIL=noreply@example.com
  SMTP_FROM_NAME=FleetOptima

  # WhatsApp (WAHA)
  WAHA_ENABLED=true
  WAHA_API_URL=http://localhost:3000
  WAHA_API_KEY=your-api-key
  WAHA_SESSION=default
